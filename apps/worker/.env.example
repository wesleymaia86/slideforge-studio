# --- Worker App .env.example --------------------------------------------------
NODE_ENV="development"

# --- Database ----------------------------------------------------------------
DATABASE_URL="postgresql://slideforge:slideforge_dev@localhost:5432/slideforge_dev"
DIRECT_DATABASE_URL="postgresql://slideforge:slideforge_dev@localhost:5432/slideforge_dev"

# --- Redis -------------------------------------------------------------------
REDIS_URL="redis://:slideforge_dev@localhost:6379"

# --- Storage -----------------------------------------------------------------
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_BUCKET="slideforge-uploads"
STORAGE_ACCESS_KEY="slideforge"
STORAGE_SECRET_KEY="slideforge_dev_secret"
STORAGE_REGION="us-east-1"
STORAGE_FORCE_PATH_STYLE="true"

# --- Worker Tuning -----------------------------------------------------------
WORKER_CONCURRENCY=5
WORKER_MAX_STALLED_COUNT=3
WORKER_STALL_INTERVAL_MS=30000

# --- AI Providers ------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# --- Observability -----------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL="info"
