{
  "name": "@slideforge/worker",
  "version": "0.1.0",
  "private": true,
  "description": "SlideForge Studio — Background job worker (BullMQ)",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "start": "node dist/main",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@slideforge/types": "workspace:*",
    "@slideforge/config": "workspace:*",
    "@slideforge/shared": "workspace:*",
    "@slideforge/ai": "workspace:*",
    "@slideforge/slides": "workspace:*",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.25.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "rimraf": "^6.0.0"
  }
}
