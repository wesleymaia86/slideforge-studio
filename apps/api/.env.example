# --- API App .env.example -----------------------------------------------------
# Inherits all vars from root .env.example — add API-specific vars here.

NODE_ENV="development"
PORT=3001
HOST="0.0.0.0"
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# --- Database ----------------------------------------------------------------
DATABASE_URL="postgresql://slideforge:slideforge_dev@localhost:5432/slideforge_dev"
DIRECT_DATABASE_URL="postgresql://slideforge:slideforge_dev@localhost:5432/slideforge_dev"

# --- Redis -------------------------------------------------------------------
REDIS_URL="redis://:slideforge_dev@localhost:6379"

# --- Storage -----------------------------------------------------------------
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_BUCKET="slideforge-uploads"
STORAGE_ACCESS_KEY="slideforge"
STORAGE_SECRET_KEY="slideforge_dev_secret"
STORAGE_REGION="us-east-1"
STORAGE_FORCE_PATH_STYLE="true"

# --- Auth --------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET="change-me-at-least-32-chars-long-local-dev-only"
JWT_EXPIRY="15m"
JWT_REFRESH_SECRET="change-me-refresh-at-least-32-chars-local-dev"
JWT_REFRESH_EXPIRY="30d"

# --- Worker internal callbacks (must match worker WORKER_API_KEY) --------------
WORKER_API_KEY="change-me-worker-shared-secret-min-32-chars"

# --- AI Providers ------------------------------------------------------------
# Set at least one provider for AI features to work
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
# Azure OpenAI (optional)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# --- Email -------------------------------------------------------------------
EMAIL_PROVIDER="console"
EMAIL_FROM="noreply@slideforge.io"
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Observability -----------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL="info"
