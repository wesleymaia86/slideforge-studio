// ─── Prisma Schema — SlideForge Studio ───────────────────────────────────────
// Multi-tenant workspace model with RBAC, AI pipeline, and pgvector support.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector", schema: "extensions"), uuid_ossp(map: "uuid-ossp", schema: "extensions"), pg_trgm(map: "pg_trgm", schema: "extensions")]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum MemberRole {
  owner
  admin
  editor
  viewer
  approver
}

enum ProjectStatus {
  draft
  processing
  ready
  archived
}

enum DeckStatus {
  draft
  generating
  ready
  published
  archived
}

enum SlideLayout {
  title
  content
  two_column
  image_left
  image_right
  full_image
  quote
  metrics
  divider
  blank
}

enum JobType {
  file_parse
  ai_pipeline
  export
  thumbnail
}

enum JobStatus {
  pending
  running
  completed
  failed
  cancelled
  retrying
}

enum ExportFormat {
  pptx
  pdf
  png
  html
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  incomplete
  paused
}

enum PlanTier {
  free
  starter
  pro
  enterprise
}

enum AuditAction {
  create
  update
  delete
  publish
  export
  invite
  revoke
  login
  logout
}

enum FileAssetType {
  upload
  export
  thumbnail
  brand_logo
  brand_font
}

enum InsightType {
  summary
  key_points
  tone
  audience
  action_items
  custom
}

// ─── Identity & Access ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  email         String    @unique @db.VarChar(320)
  name          String?   @db.VarChar(200)
  avatarUrl     String?
  emailVerified Boolean   @default(false)
  passwordHash  String?
  isSuperAdmin  Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships  Membership[]
  fileAssets   FileAsset[]
  deckComments Comment[]
  auditLogs    AuditLog[]
  usageEvents  UsageEvent[]
  exportJobs   ExportJob[]
  projects     Project[]

  @@index([email])
  @@map("users")
}

model Workspace {
  id        String   @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(200)
  slug      String   @unique @db.VarChar(100)
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   Membership[]
  projects      Project[]
  brandKits     BrandKit[]
  fileAssets    FileAsset[]
  processingJobs ProcessingJob[]
  auditLogs     AuditLog[]
  usageEvents   UsageEvent[]
  decks         Deck[]
  subscription  Subscription?

  @@index([slug])
  @@map("workspaces")
}

model Membership {
  id              String     @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  userId          String     @db.Uuid
  workspaceId     String     @db.Uuid
  role            MemberRole @default(viewer)
  invitedByUserId String?    @db.Uuid
  joinedAt        DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
  @@map("memberships")
}

// ─── Branding ─────────────────────────────────────────────────────────────────

model BrandKit {
  id               String   @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  workspaceId      String   @db.Uuid
  name             String   @db.VarChar(200)
  primaryColor     String?  @db.VarChar(7)
  secondaryColor   String?  @db.VarChar(7)
  accentColor      String?  @db.VarChar(7)
  backgroundColor  String?  @db.VarChar(7)
  fontHeading      String?  @db.VarChar(100)
  fontBody         String?  @db.VarChar(100)
  logoFileId       String?  @db.Uuid
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  decks     Deck[]

  @@index([workspaceId])
  @@map("brand_kits")
}

// ─── Files & Storage ──────────────────────────────────────────────────────────

model FileAsset {
  id                 String        @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  workspaceId        String        @db.Uuid
  projectId          String?       @db.Uuid
  uploadedByUserId   String        @db.Uuid
  type               FileAssetType @default(upload)
  originalName       String        @db.VarChar(500)
  mimeType           String        @db.VarChar(200)
  sizeBytes          BigInt
  storageKey         String        @unique
  storageUrl         String?
  checksum           String?       @db.VarChar(64)
  createdAt          DateTime      @default(now())

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploadedBy      User             @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  parsedArtifacts ParsedArtifact[]
  exportJobs      ExportJob[]

  @@index([workspaceId])
  @@index([projectId])
  @@map("file_assets")
}

// ─── Projects & AI Processing ─────────────────────────────────────────────────

model Project {
  id                String        @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  workspaceId       String        @db.Uuid
  createdByUserId   String        @db.Uuid
  name              String        @db.VarChar(300)
  description       String?       @db.Text
  status            ProjectStatus @default(draft)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy    User             @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  fileAssets   FileAsset[]
  artifacts    ParsedArtifact[]
  insights     Insight[]
  decks        Deck[]
  processingJobs ProcessingJob[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("projects")
}

model ParsedArtifact {
  id                String    @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  projectId         String    @db.Uuid
  fileAssetId       String    @db.Uuid
  rawText           String?   @db.Text
  structuredContent Json?
  pageCount         Int?
  wordCount         Int?
  /// pgvector embedding (1536 dims for text-embedding-3-small)
  embeddingVector   Unsupported("vector(1536)")?
  embeddingModel    String?   @db.VarChar(100)
  createdAt         DateTime  @default(now())

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("parsed_artifacts")
}

model Insight {
  id            String      @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  projectId     String      @db.Uuid
  type          InsightType
  content       String      @db.Text
  modelUsed     String?     @db.VarChar(100)
  promptVersion String?     @db.VarChar(20)
  createdAt     DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, type])
  @@map("insights")
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

model ProcessingJob {
  id          String    @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  workspaceId String    @db.Uuid
  projectId   String?   @db.Uuid
  deckId      String?   @db.Uuid
  type        JobType
  status      JobStatus @default(pending)
  progress    Int       @default(0)
  errorMessage String?  @db.Text
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  payload     Json
  result      Json?
  queuedAt    DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([type, status])
  @@index([queuedAt])
  @@map("processing_jobs")
}

// ─── Decks & Slides ───────────────────────────────────────────────────────────

model Deck {
  id                String     @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  projectId         String     @db.Uuid
  workspaceId       String     @db.Uuid
  createdByUserId   String     @db.Uuid
  title             String     @db.VarChar(300)
  description       String?    @db.Text
  status            DeckStatus @default(draft)
  brandKitId        String?    @db.Uuid
  slideCount        Int        @default(0)
  thumbnailUrl      String?
  publishedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandKit  BrandKit?  @relation(fields: [brandKitId], references: [id], onDelete: SetNull)
  slides     Slide[]
  comments   Comment[]
  exportJobs ExportJob[]
  briefings  Briefing[]

  @@index([workspaceId, status])
  @@index([projectId])
  @@map("decks")
}

model Slide {
  id           String      @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  deckId       String      @db.Uuid
  position     Int
  layout       SlideLayout @default(content)
  content      Json
  style        Json?
  speakerNotes String?     @db.Text
  thumbnailUrl String?
  aiGenerated  Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  deck     Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@unique([deckId, position])
  @@index([deckId])
  @@map("slides")
}

model Comment {
  id                 String    @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  deckId             String    @db.Uuid
  slideId            String?   @db.Uuid
  authorUserId       String    @db.Uuid
  body               String    @db.Text
  resolvedAt         DateTime?
  resolvedByUserId   String?   @db.Uuid
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  slide  Slide? @relation(fields: [slideId], references: [id], onDelete: SetNull)
  author User   @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([deckId])
  @@index([slideId])
  @@map("comments")
}

// ─── Export ───────────────────────────────────────────────────────────────────

model ExportJob {
  id                  String       @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  deckId              String       @db.Uuid
  requestedByUserId   String       @db.Uuid
  format              ExportFormat
  status              JobStatus    @default(pending)
  fileAssetId         String?      @db.Uuid
  errorMessage        String?      @db.Text
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  deck        Deck       @relation(fields: [deckId], references: [id], onDelete: Cascade)
  requestedBy User       @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)
  fileAsset   FileAsset? @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)

  @@index([deckId, status])
  @@map("export_jobs")
}

// ─── Subscriptions & Plans ────────────────────────────────────────────────────

model Plan {
  id                          String   @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  tier                        PlanTier @unique
  name                        String   @db.VarChar(100)
  description                 String?  @db.Text
  priceMonthlyUsd             Int      @default(0)
  priceYearlyUsd              Int      @default(0)
  maxWorkspaceMembers         Int      @default(5)
  maxProjectsPerWorkspace     Int      @default(10)
  maxDecksPerProject          Int      @default(5)
  maxSlidesPerDeck            Int      @default(30)
  maxStorageGb                Int      @default(1)
  aiCreditsPerMonth           Int      @default(100)
  allowCustomBranding         Boolean  @default(false)
  allowApiAccess              Boolean  @default(false)
  allowSso                    Boolean  @default(false)
  stripePriceIdMonthly        String?
  stripePriceIdYearly         String?
  isActive                    Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                     String             @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  workspaceId            String             @unique @db.Uuid
  planId                 String             @db.Uuid
  status                 SubscriptionStatus @default(trialing)
  externalSubscriptionId String?            @db.VarChar(200)
  externalCustomerId     String?            @db.VarChar(200)
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  cancelAtPeriodEnd      Boolean            @default(false)
  trialEndsAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([externalSubscriptionId])
  @@index([externalCustomerId])
  @@map("subscriptions")
}

// ─── Briefing & Outline ───────────────────────────────────────────────────────

model Briefing {
  id          String   @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  deckId      String   @db.Uuid
  audience    String?  @db.Text
  objective   String?  @db.Text
  toneVoice   String?  @db.VarChar(200)
  contextJson Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deck     Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)
  outlines Outline[]

  @@index([deckId])
  @@map("briefings")
}

model Outline {
  id          String   @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  briefingId  String   @db.Uuid
  slidesJson  Json
  createdAt   DateTime @default(now())

  briefing Briefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)

  @@index([briefingId])
  @@map("outlines")
}

// ─── Observability ────────────────────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  workspaceId String      @db.Uuid
  actorUserId String?     @db.Uuid
  action      AuditAction
  entityType  String      @db.VarChar(100)
  entityId    String      @db.Uuid
  before      Json?
  after       Json?
  ipAddress   String?     @db.VarChar(45)
  userAgent   String?     @db.Text
  createdAt   DateTime    @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("audit_logs")
}

model UsageEvent {
  id          String   @id @default(dbgenerated("extensions.gen_random_uuid()")) @db.Uuid
  workspaceId String   @db.Uuid
  userId      String?  @db.Uuid
  eventType   String   @db.VarChar(100)
  quantity    Int      @default(1)
  metadata    Json?
  recordedAt  DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, recordedAt(sort: Desc)])
  @@index([eventType, recordedAt])
  @@map("usage_events")
}
