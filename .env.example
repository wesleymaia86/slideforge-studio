# ?????????????????????????????????????????????????????????
#  SlideForge Studio Ś environment variables template
#  Copy to .env and fill real values. NEVER commit .env.
# ?????????????????????????????????????????????????????????

NODE_ENV=development

# ?? Database ?????????????????????????????????????????????
# Use the pooled URL for runtime; direct URL for Prisma migrations
DATABASE_URL=postgresql://slideforge:change_me@localhost:5432/slideforge
DIRECT_DATABASE_URL=postgresql://slideforge:change_me@localhost:5432/slideforge

# ?? Redis ????????????????????????????????????????????????
REDIS_URL=redis://localhost:6379

# ?? Storage (MinIO / AWS S3 / Cloudflare R2) ?????????????
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=slideforge
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true          # set true for MinIO/LocalStack

# ?? API service ??????????????????????????????????????????
PORT=3001
HOST=0.0.0.0
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000          # Used for CORS

# ?? Auth / JWT ???????????????????????????????????????????
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_min_32_chars_random_string_here
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=change_me_another_32_char_random_string
JWT_REFRESH_EXPIRY=30d

# ?? NextAuth (web service) ???????????????????????????????
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_nextauth_secret_min_32_chars

# ?? LLM providers (at least one required for AI features) ?
OPENAI_API_KEY=sk-...                  # Optional: direct OpenAI
# ANTHROPIC_API_KEY=                   # Optional: direct Anthropic
# GOOGLE_AI_API_KEY=                   # Optional: Google Gemini

# ?? Email ????????????????????????????????????????????????
EMAIL_PROVIDER=console                 # console | resend | sendgrid | smtp
EMAIL_FROM=noreply@slideforge.io
# RESEND_API_KEY=re_...                # Required if EMAIL_PROVIDER=resend
# SENDGRID_API_KEY=                    # Required if EMAIL_PROVIDER=sendgrid

# ?? Payments (optional) ??????????????????????????????????
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ?? Observability (optional) ?????????????????????????????
LOG_LEVEL=info
# SENTRY_DSN=https://...@sentry.io/...

# ?? GitHub App (for Coolify private repo access) ??????????
# Collect these after creating the GitHub App Ś see docs/deployment.md
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# GITHUB_APP_WEBHOOK_SECRET=
# GITHUB_APP_PRIVATE_KEY_B64=          # base64 -w0 private-key.pem
